```env
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_user_id
DATABASE_URL=postgresql://user:password@host:port/database
REQUIRED_CHANNEL=@channel_username   # مثلاً @MyChannel أو معرف القناة الرقمي
REFERRAL_REQUIRED=10                 # عدد الإحالات المطلوبة للحصول على كود ChatGPT مجاناً
```
